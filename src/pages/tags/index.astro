---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Tag from "../../components/Tag.astro";

const allPosts = await getCollection("blog");

const tags = [
  ...new Set(allPosts.map((post: any) => post.data.tags).flat()),
].sort((a, b) => a.localeCompare(b));
const pageTitle = "Dispatch Tags";
---

<BaseLayout pageTitle={pageTitle}>
  <section class="mx-auto max-w-5xl">
    <h1 class="text-center">Dispatch Tags</h1>
    <p class="mt-3 mb-8 text-center text-text-muted">
      Browse mission logs by topic.
    </p>

    <div class="mx-auto flex max-w-4xl flex-wrap justify-center gap-2">
      {tags.map((tag) => <Tag tag={tag} isLink />)}
    </div>
  </section>
</BaseLayout>
