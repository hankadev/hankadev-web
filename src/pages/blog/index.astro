---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import PostListCards from "../../components/PostListCards.astro";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout pageTitle="hankadev blog">
  <section class="mx-auto max-w-5xl">
    <h1 class="text-center">Outer Rim Dispatches</h1>
    <p class="mt-3 mb-8 text-center text-text-muted">
      Bounty hunter's field journal about hunting bugs, fixing glitches, and
      shipping clean code.
    </p>
  </section>

  <PostListCards posts={allPosts} />
</BaseLayout>
