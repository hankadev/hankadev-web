---
import Tag from "./Tag.astro";

const { posts } = Astro.props;
---

<ol class="mx-auto grid max-w-5xl grid-cols-1 gap-5">
  {
    posts.map((post: any) => (
      <li class="list-none">
        <a
          href={`/blog/${post.id}/`}
          class="group relative block h-full border border-border bg-surface/75 p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/75 hover:bg-surface/95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/55"
        >
          <span class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-accent/60 to-transparent opacity-0 transition-opacity duration-200 group-hover:opacity-100" />
          <h2 class="text-xl text-primary leading-snug transition-colors duration-200 group-hover:text-accent">
            {post.data.title}
          </h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <Tag tag={tag} />
            ))}
          </div>
          <p class="mt-4 text-base leading-relaxed text-text-muted">
            {post.data.description}
          </p>
        </a>
      </li>
    ))
  }
</ol>
