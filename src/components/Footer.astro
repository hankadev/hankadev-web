---
const currentYear = new Date().getFullYear();
---

<footer class="flex justify-center border-t border-border">
  <div class="container px-6 md:px-8 py-5 text-text-muted relative">
    <span
      class="absolute inset-x-6 md:inset-x-8 top-0 h-px"
      style="background-image: linear-gradient(to right, transparent, color-mix(in oklab, var(--color-accent) 45%, transparent), transparent);"
    ></span>
    <div
      class="flex flex-col sm:flex-row gap-2 sm:gap-0 justify-between sm:items-center text-[0.95rem]"
    >
      <span>&copy; {currentYear} Hana Klingová</span>
      <p>
        Built with ♥️ and <a
          class="underline decoration-primary/60 underline-offset-2 hover:text-primary transition-colors"
          href="https://astro.build/"
          target="_blank">Astro</a
        >
      </p>
    </div>
  </div>
</footer>
